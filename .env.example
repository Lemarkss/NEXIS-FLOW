# Configurações de Produção
NODE_ENV=production
PORT=3000

# URL do seu aplicativo (ex: https://seu-app.com)
APP_URL=

# Chaves do Stripe (Pegue no painel do Stripe em modo Live)
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Chave da Gemini API (Opcional se usar o Admin SDK)
GEMINI_API_KEY=

# Configurações do Firebase (Geralmente injetadas via firebase-applet-config.json)
# Mas podem ser definidas manualmente se necessário
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
